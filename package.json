{
  "name": "get-into-feed-client",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "cross-env NODE_ENV=production pm2 start npm --name \"getintofeed-frontend\" -- start",
    "clean": "rm -rf .next node_modules package-lock.json && npm install",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@portabletext/react": "^6.0.3",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.19.0",
    "clsx": "^2.1.0",
    "framer-motion": "^12.38.0",
    "hamo": "^1.0.0-dev.10",
    "lenis": "^1.3.23",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-sanity": "^12.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "sanity": "^5.22.0",
    "sanity-plugin-media": "^4.1.1",
    "styled-components": "^6.3.12",
    "tailwind-merge": "^2.2.1",
    "tempus": "^1.0.0-dev.17",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.3",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.38",
    "postcss-import": "^16.0.1",
    "postcss-nesting": "^12.1.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.1"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
